---
---

<div id="new-task-modal" class="hidden fixed inset-0 bg-slate-900/50 backdrop-blur-sm flex items-center justify-center z-50 p-4">
  <div class="bg-white rounded-2xl shadow-xl w-full max-w-md animate-scale-in">
    <div class="px-6 py-4 border-b border-slate-200">
      <h3 class="text-lg font-semibold text-slate-900">Nueva Tarea</h3>
    </div>
    <form id="new-task-form" class="p-6 space-y-4">
      <input type="hidden" id="task-column-id">
      <div>
        <label for="task-title" class="block text-sm font-medium text-slate-700 mb-1">Título</label>
        <input type="text" id="task-title" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Nombre de la tarea" required>
      </div>
      <div>
        <label for="task-desc" class="block text-sm font-medium text-slate-700 mb-1">Descripción</label>
        <textarea id="task-desc" rows="3" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent resize-none" placeholder="Detalles de la tarea..."></textarea>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="task-priority" class="block text-sm font-medium text-slate-700 mb-1">Prioridad</label>
          <select id="task-priority" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent bg-white">
            <option value="low">Baja</option>
            <option value="medium" selected>Media</option>
            <option value="high">Alta</option>
            <option value="urgent">Urgente</option>
          </select>
        </div>
        <div>
          <label for="task-due-date" class="block text-sm font-medium text-slate-700 mb-1">Fecha límite</label>
          <input type="date" id="task-due-date" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent">
        </div>
      </div>
    </form>
    <div class="px-6 py-4 border-t border-slate-200 flex justify-end gap-3">
      <button type="button" id="cancel-task-btn" class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-colors">Cancelar</button>
      <button type="submit" form="new-task-form" class="px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium rounded-lg transition-colors">Crear Tarea</button>
    </div>
  </div>
</div>
